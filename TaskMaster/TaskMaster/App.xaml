<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="TaskMaster.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskMaster">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="AppFontFamily">ms-appx:///Assets/Fonts/HarmonyOS_SansSC_Regular.ttf#HarmonyOS Sans SC</FontFamily>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            </Style>

            <Style TargetType="TextElement">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            </Style>

            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            </Style>

            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
