<Page
    x:Class="TaskMaster.Views.SamplePage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:TaskMaster.ViewModels"
    xmlns:models="using:TaskMaster.Models"
    mc:Ignorable="d">

    <Page.DataContext>
        <viewModels:SamplePage1ViewModel />
    </Page.DataContext>

    <Grid Padding="24">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#f8fafc" Offset="0" />
                <GradientStop Color="#eef2ff" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="动词变形查询"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#0f172a" />
                <TextBlock Text="输入辞書形，查看各类活用。"
                           FontSize="13"
                           Foreground="#64748b" />
            </StackPanel>

            <Border Grid.Row="1"
                    Padding="18"
                    CornerRadius="22"
                    Background="#ffffff"
                    BorderBrush="#e2e8f0"
                    BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBox Height="38"
                             PlaceholderText="例如：書く、食べる、する、来る"
                             FontSize="16"
                             Text="{x:Bind ViewModel.InputWord, Mode=TwoWay}" />

                    <Button Grid.Column="1"
                            Content="查询"
                            MinWidth="96"
                            Height="38"
                            Command="{x:Bind ViewModel.SearchCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="18"
                    CornerRadius="22"
                    Background="#ffffff"
                    BorderBrush="#e2e8f0"
                    BorderThickness="1">
                <Grid>
                    <TextBlock Text="结果"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0f172a"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top" />

                    <TextBlock Text="{x:Bind ViewModel.CenterMessage, Mode=OneWay}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#94a3b8"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.CenterMessageVisibility, Mode=OneWay}" />

                    <ListView ItemsSource="{x:Bind ViewModel.Forms, Mode=OneWay}"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="0"
                              Margin="0,28,0,0"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VerbConjugationItem">
                                <Border Margin="0,0,0,10"
                                        Padding="14,12"
                                        CornerRadius="16"
                                        Background="#f8fafc"
                                        BorderBrush="#e2e8f0"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="120,*,Auto">
                                        <TextBlock Text="{x:Bind FormName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#334155" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind FormValue}"
                                                   FontSize="13"
                                                   Foreground="#0f172a" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind AvailabilityText}"
                                                   FontSize="12"
                                                   Foreground="#94a3b8"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>