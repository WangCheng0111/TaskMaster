<Page
    x:Class="TaskMaster.Views.SamplePage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:TaskMaster.ViewModels"
    xmlns:models="using:TaskMaster.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.DataContext>
        <viewModels:SamplePage1ViewModel />
    </Page.DataContext>

    <Page.Resources>
        <!-- ═══════════════════════════════════════════════════════════
             EASING — ExponentialEase gives Apple-like "settle" feel
             ═══════════════════════════════════════════════════════════ -->
        <ExponentialEase x:Key="AppleEaseOut" EasingMode="EaseOut" Exponent="3.5" />
        <ExponentialEase x:Key="AppleEaseOutStrong" EasingMode="EaseOut" Exponent="5" />

        <!-- ═══════════════════════════════════════════════════════════
             COLOR — iOS system palette, indigo accent
             ═══════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="SystemBackgroundBrush" Color="#F2F2F7" />
        <SolidColorBrush x:Key="LabelBrush" Color="#1C1C1E" />
        <SolidColorBrush x:Key="SecondaryLabelBrush" Color="#8E8E93" />
        <SolidColorBrush x:Key="TertiaryLabelBrush" Color="#C7C7CC" />
        <SolidColorBrush x:Key="SeparatorBrush" Color="#E5E5EA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5856D6" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34C759" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF3B30" />

        <!-- ═══════════════════════════════════════════════════════════
             PAGE ENTRANCE — cascade header → search → results
             ═══════════════════════════════════════════════════════════ -->
        <Storyboard x:Key="PageEntranceStoryboard">
            <DoubleAnimation Storyboard.TargetName="HeaderGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.55"
                             BeginTime="0:0:0"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="HeaderTranslate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="0" Duration="0:0:0.55"
                             BeginTime="0:0:0"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="SearchBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.55"
                             BeginTime="0:0:0.08"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="SearchTranslate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="0" Duration="0:0:0.55"
                             BeginTime="0:0:0.08"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="ResultsPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6"
                             BeginTime="0:0:0.16"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="ResultsTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.6"
                             BeginTime="0:0:0.16"
                             EasingFunction="{StaticResource AppleEaseOut}" />
        </Storyboard>

        <!-- ═══════════════════════════════════════════════════════════
             TOAST — scale-in (spring-like), scale-out (snappy exit)
             ═══════════════════════════════════════════════════════════ -->
        <Storyboard x:Key="ToastInStoryboard">
            <DoubleAnimation Storyboard.TargetName="ToastScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.92" To="1" Duration="0:0:0.45"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="ToastScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.92" To="1" Duration="0:0:0.45"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="CopyFeedbackBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"
                             EasingFunction="{StaticResource AppleEaseOut}" />
        </Storyboard>

        <Storyboard x:Key="ToastOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="ToastScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.95" Duration="0:0:0.25"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="ToastScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.95" Duration="0:0:0.25"
                             EasingFunction="{StaticResource AppleEaseOut}" />
            <DoubleAnimation Storyboard.TargetName="CopyFeedbackBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.25" />
        </Storyboard>

        <!-- ═══════════════════════════════════════════════════════════
             LAYOUT
             ═══════════════════════════════════════════════════════════ -->
        <UniformGridLayout x:Key="FormGridLayout"
                           MinItemWidth="200"
                           MinItemHeight="92"
                           MinRowSpacing="12"
                           MinColumnSpacing="12" />

        <!-- ═══════════════════════════════════════════════════════════
             BORDERLESS TEXTBOX — clean, no chrome
             ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="BorderlessTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1C1C1E" />
            <Setter Property="PlaceholderForeground" Value="#C7C7CC" />
            <Setter Property="SelectionHighlightColor" Value="#5856D6" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver" />
                                    <VisualState x:Name="Focused" />
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentElement.Foreground" Value="#C7C7CC" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ScrollViewer x:Name="ContentElement"
                                          Grid.Row="0"
                                          HorizontalScrollMode="Auto"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollMode="Disabled"
                                          VerticalScrollBarVisibility="Disabled"
                                          IsHorizontalRailEnabled="True"
                                          IsVerticalRailEnabled="False"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"
                                          ZoomMode="Disabled" />
                            <ContentPresenter x:Name="PlaceholderTextContentPresenter"
                                              Grid.Row="0"
                                              Content="{TemplateBinding PlaceholderText}"
                                              Foreground="{TemplateBinding PlaceholderForeground}"
                                              FontSize="{TemplateBinding FontSize}"
                                              FontFamily="{TemplateBinding FontFamily}"
                                              Padding="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              IsHitTestVisible="False" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             PRIMARY BUTTON — solid accent, scale-on-press
             ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5856D6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyMedium}" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#4F52CC" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#4547B5" />
                                        </VisualState.Setters>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.97" Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.97" Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#E5E5EA" />
                                            <Setter Target="ContentPresenter.Foreground" Value="#C7C7CC" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Foreground="{TemplateBinding Foreground}"
                                              FontSize="{TemplateBinding FontSize}"
                                              FontWeight="{TemplateBinding FontWeight}"
                                              FontFamily="{TemplateBinding FontFamily}"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             CLEAR BUTTON — circular icon, subtle hover
             ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="ClearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#8E8E93" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#E5E5EA" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#D1D1D6" />
                                        </VisualState.Setters>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.9" Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.9" Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              Foreground="{TemplateBinding Foreground}"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             FORM CARD — white surface, ThemeShadow depth, scale-on-press
             ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="FormCardButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#0000000F" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FAFAFC" />
                                            <Setter Target="Root.BorderBrush" Value="#00000014" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#F5F5F7" />
                                            <Setter Target="Root.BorderBrush" Value="#0000001A" />
                                        </VisualState.Setters>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.97" Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                            <DoubleAnimation Storyboard.TargetName="RootScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.97" Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource AppleEaseOut}" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#F5F5F7" />
                                            <Setter Target="Root.BorderBrush" Value="Transparent" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="ShadowTarget"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}" />
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5"
                                    Translation="0,0,6">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Stretch" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             FORM CARD DATA TEMPLATE
             Wrapper Grid handles entrance stagger; Button handles press
             ═══════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="FormCardTemplate" x:DataType="models:VerbConjugationItem">
            <Grid Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="14" />
                </Grid.RenderTransform>
                <Button Style="{StaticResource FormCardButtonStyle}"
                        Click="FormCard_Click"
                        Tag="{x:Bind FormValue}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{x:Bind FormName}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="{StaticResource AppFontFamilyMedium}"
                                   Foreground="#5856D6"
                                   CharacterSpacing="15"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind FormValue}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   FontFamily="{StaticResource AppFontFamilyMedium}"
                                   Foreground="#1C1C1E"
                                   CharacterSpacing="-5"
                                   VerticalAlignment="Bottom"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         PAGE — iOS grouped background, generous padding
         ═══════════════════════════════════════════════════════════ -->
    <Grid Background="{StaticResource SystemBackgroundBrush}"
          Padding="40,36,40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header — Large title pattern ═══ -->
        <Grid x:Name="HeaderGrid"
              Grid.Row="0"
              Opacity="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="HeaderTranslate" Y="10" />
            </Grid.RenderTransform>
            <StackPanel Grid.Column="0" Spacing="5" VerticalAlignment="Center">
                <TextBlock Text="动词活用查询"
                           FontSize="30"
                           FontWeight="SemiBold"
                           FontFamily="{StaticResource AppFontFamilyMedium}"
                           CharacterSpacing="-20"
                           Foreground="#1C1C1E" />
                <TextBlock Text="输入辞書形，一键查看各类活用形式"
                           FontSize="14"
                           FontFamily="{StaticResource AppFontFamily}"
                           Foreground="#8E8E93" />
            </StackPanel>
            <Border Grid.Column="1"
                    Visibility="{x:Bind ViewModel.VerbTypeBadgeVisibility, Mode=OneWay}"
                    CornerRadius="14"
                    Padding="14,6"
                    Background="#1F5856D6"
                    VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.VerbTypeText, Mode=OneWay}"
                           Foreground="#5856D6"
                           FontSize="13"
                           FontWeight="SemiBold"
                           FontFamily="{StaticResource AppFontFamilyMedium}"
                           CharacterSpacing="5"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <!-- ═══ Row 1: Search field — Apple-style rounded input ═══ -->
        <Border x:Name="SearchBorder"
                Grid.Row="1"
                Opacity="0"
                CornerRadius="12"
                Background="#FFFFFF"
                BorderBrush="#E5E5EA"
                BorderThickness="1"
                Padding="4,3,4,3"
                Margin="0,24,0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SearchTranslate" Y="10" />
            </Border.RenderTransform>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <FontIcon Grid.Column="0"
                          Glyph="&#xE721;"
                          FontSize="16"
                          Foreground="#C7C7CC"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         x:Name="InputBox"
                         Style="{StaticResource BorderlessTextBoxStyle}"
                         PlaceholderText="例如：書く、食べる、する、来る"
                         FontSize="15"
                         Padding="10,0,0,0"
                         Text="{x:Bind ViewModel.InputWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="InputBox_KeyDown"
                         GotFocus="InputBox_GotFocus"
                         LostFocus="InputBox_LostFocus" />
                <Button Grid.Column="2"
                        Style="{StaticResource ClearButtonStyle}"
                        Margin="2,0,2,0"
                        Visibility="{x:Bind ViewModel.HasInput, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{x:Bind ViewModel.ClearInputCommand}">
                    <FontIcon Glyph="&#xE711;"
                              FontSize="11"
                              Foreground="#8E8E93" />
                </Button>
                <Button Grid.Column="3"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{x:Bind ViewModel.SearchCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="13"
                                  Foreground="White"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="查询"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Row 2: Results — cards on gray canvas with shadow depth ═══ -->
        <Grid x:Name="ResultsPanel"
              Grid.Row="2"
              Opacity="0"
              Margin="0,24,0,0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ResultsTranslate" Y="14" />
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Section header — iOS grouped style, hidden when no results -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="活用形式"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource AppFontFamilyMedium}"
                               CharacterSpacing="15"
                               Foreground="#8E8E93"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.ResultsCountText, Mode=OneWay}"
                               FontSize="13"
                               Foreground="#C7C7CC"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="点击卡片复制结果"
                           FontSize="11"
                           Foreground="#C7C7CC"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Content area -->
            <Grid Grid.Row="1" Margin="0,14,0,0">
                <!-- Results: scrollable card grid -->
                <ScrollViewer Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0">
                    <ItemsRepeater x:Name="FormsRepeater"
                                   ItemsSource="{x:Bind ViewModel.Forms, Mode=OneWay}"
                                   ItemTemplate="{StaticResource FormCardTemplate}"
                                   Layout="{StaticResource FormGridLayout}"
                                   ElementPrepared="FormsRepeater_ElementPrepared"
                                   ElementClearing="FormsRepeater_ElementClearing" />
                </ScrollViewer>

                <!-- Empty / Error state — calm, centered -->
                <StackPanel Visibility="{x:Bind ViewModel.CenterMessageVisibility, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Grid HorizontalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="#1F5856D6"
                                Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="#1FFF3B30"
                                Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="24"
                                  Foreground="#5856D6"
                                  Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="!"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource AppFontFamilyBold}"
                                   Foreground="#FF3B30"
                                   Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.CenterTitle, Mode=OneWay}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   FontFamily="{StaticResource AppFontFamilyMedium}"
                                   Foreground="#1C1C1E"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.CenterSubtitle, Mode=OneWay}"
                                   FontSize="14"
                                   Foreground="#8E8E93"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="320" />
                    </StackPanel>
                </StackPanel>

                <!-- Toast — dark pill, spring scale-in, bottom center -->
                <Border x:Name="CopyFeedbackBorder"
                        Visibility="Collapsed"
                        Opacity="0"
                        CornerRadius="12"
                        Background="#2C2C2E"
                        Padding="16,9"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,12"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ToastScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE73E;"
                                  FontSize="13"
                                  Foreground="#34C759"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="CopyFeedbackText"
                                   FontSize="13"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
